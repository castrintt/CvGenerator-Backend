# API
PORT=3000

# CORS (carregado no bootstrap via dotenv — ver main.ts)
FRONTEND_URL=http://localhost:5173

# MySQL (app + docker-compose)
# Em desenvolvimento local sem Docker, use localhost e a porta do seu MySQL (ex.: 3307).
DATABASE_HOST=localhost
DATABASE_PORT=3307
DATABASE_USER=root
DATABASE_PASSWORD=altere_esta_senha
DATABASE_NAME=cvgenerator

# Porta do MySQL no host quando usar docker compose (mapeamento host:container)
MYSQL_HOST_PORT=3307
